}

.moveUpDown2:nth-child(1) {
  animation-delay: 0.3s;
}

.moveUpDown2:nth-child(2) {
  animation-delay: 0.5s;
}

.moveUpDown2:nth-child(3) {
  animation-delay: 0.7s;
}

