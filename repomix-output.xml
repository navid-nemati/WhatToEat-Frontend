.moveUpDown3 {
  animation: moveUpDown 1.4s ease-in-out infinite;
}

.moveUpDown3:nth-child(1) {
  animation-delay: 0.5s;
}

.moveUpDown3:nth-child(2) {
  animation-delay: 0.7s;
}

.moveUpDown3:nth-child(3) {
  animation-delay: 0.9s;
}

