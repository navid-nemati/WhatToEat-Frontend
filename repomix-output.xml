                <button
                    type="submit"
                    disabled={isPending || isSubmitting}
                    className="bg-sky-300 px-3 py-2 rounded-md text-white
                    text-shadow-sm transition-all duration-200 hover:scale-105
                    hover:shadow-md">
                    {isPending || isSubmitting ? "اندکی تأمل" : "افزودن"}
                </button>
            </form>
        </div>
    )
}
