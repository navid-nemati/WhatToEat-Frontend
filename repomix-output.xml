                toast.error(err.message || "خطا")
            }
        });
    }

    return (
        <div className="p-5 bg-emerald-100 border border-emerald-200 rounded-lg">
            <div className="mb-3">
                <span className="text-lg">افزودن ماده اولیه</span>
